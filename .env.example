# ============================================================================
# Required environment variables for Railway deployment
# ============================================================================

# Postgres connection string (Railway provides this automatically when you
# add the PostgreSQL plugin — it will be injected as DATABASE_URL).
DATABASE_URL=postgres://user:pass@host:5432/dbname

# Long random string used to sign session cookies. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string

# Port the API server listens on. Railway sets this automatically — only
# set it manually for local runs.
PORT=8080

# Set to "production" on Railway (Railway sets it automatically).
NODE_ENV=production

# ----------------------------------------------------------------------------
# Stripe (card / Google Pay / Apple Pay payments)
# ----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_live_or_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ----------------------------------------------------------------------------
# Czech QR bank transfer
# ----------------------------------------------------------------------------
BANK_IBAN=CZ0000000000000000000000
BANK_RECIPIENT_NAME=Your Company Name

# ----------------------------------------------------------------------------
# Object storage (gallery photo uploads) — S3-compatible
# Works with AWS S3, Cloudflare R2, Backblaze B2, MinIO, etc.
# ----------------------------------------------------------------------------
# Bucket name
S3_BUCKET=kyrgyzstan-gallery

# AWS S3: use the region (e.g. "us-east-1"). For Cloudflare R2 use "auto".
S3_REGION=auto

# Custom endpoint URL. Leave unset for AWS S3.
#   Cloudflare R2: https://<account-id>.r2.cloudflarestorage.com
#   Backblaze B2:  https://s3.<region>.backblazeb2.com
#   MinIO:         https://your-minio-host
S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com

# Access credentials (R2: API token with R/W to the bucket)
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Set to "true" for R2 / Backblaze / MinIO. Leave unset (or "false") for AWS S3.
S3_FORCE_PATH_STYLE=true
